# Shared config for the examples/ CLIs. Copy to examples/.env and load with:
#   node --env-file=examples/.env examples/satora-cli-arkade.js ...
#
# A single seed backs every example wallet (Arkade now; EVM, Bitcoin, Spark
# later) — each example derives its chain-specific wallet from it.

# Persistent BIP-39 seed shared by all example wallets. REQUIRED. Keep it secret;
# the wallet must hold funds on the source chain you swap from.
SATORA_MNEMONIC="twelve word seed phrase goes here ..."

# Satora API (optional; production default).
SATORA_BASE_URL=https://api.satora.io/

# SQLite database for the swap client (seed/key index + per-swap state) so an
# interrupted swap survives a restart and can be recovered/refunded. Optional.
SATORA_DB=./.satora.db

# ── Bitcoin / Arkade (used by the arkade & bitcoin examples) ──────────────────
SATORA_ESPLORA=https://mempool.space/api
SATORA_ARKADE_SERVER=https://arkade.computer
