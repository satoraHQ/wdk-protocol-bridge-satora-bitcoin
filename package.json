{
  "name": "@satora/wdk-protocol-bridge-satora-bitcoin",
  "version": "1.0.0-beta.1",
  "description": "WDK module to make bitcoin BIP-32 wallets interact with the satora bridge protocol.",
  "keywords": ["wdk", "protocol", "bridge", "satora", "bitcoin"],
  "author": "bonomat &lt;philipp@lendasat.com&gt;",
  "license": "Apache-2.0",
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --fix --unsafe ."
  },
  "dependencies": {
    "@lendasat/lendaswap-sdk-pure": "^0.2.25",
    "@tetherto/wdk-wallet": "^1.0.0-beta.8",
    "bare-node-runtime": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "standard": "^17.1.2",
    "typescript": "^5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./storage": {
      "types": "./types/storage.d.ts",
      "default": "./storage.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js",
      "sample/**"
    ]
  }
}
